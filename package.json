{
  "name": "stellar-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"core,ui,web\" -c \"yellow,cyan,green\" \"pnpm -C packages/stellartools dev\" \"pnpm -C packages/ui dev\" \"pnpm -C apps/web dev\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "storybook": "pnpm -C packages/ui storybook",
    "build-storybook": "pnpm -C packages/ui build-storybook",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6"
  }
}
